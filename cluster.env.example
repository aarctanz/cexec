# cexec cluster configuration
# Copy this to cluster.env and fill in your values.
# cluster.env is gitignored — never commit passwords.

# ── Authentication ─────────────────────────────────────────────────────────────
# SSH + sudo password shared across all nodes.
CLUSTER_PASSWORD=yourpassword

# ── Inventory ──────────────────────────────────────────────────────────────────
# Auto-build node inventory from this hosts file.
# When set, inventory.yaml is not needed.
# On the master node, /etc/hosts already has all entries.
CLUSTER_HOSTS_FILE=/etc/hosts

# SSH user for all nodes (default: hpc)
CLUSTER_USER=hpc

# ── Playbook ───────────────────────────────────────────────────────────────────
# Default playbook to run (used by: cexec --playbook)
CLUSTER_PLAYBOOK=hpc-setup.yaml

# ── Paths ──────────────────────────────────────────────────────────────────────
# Directory for JSON run logs (default: logs)
CLUSTER_LOG_DIR=logs

# Path to step-cache state file (default: .cexec_state.json)
CLUSTER_STATE_FILE=.cexec_state.json
