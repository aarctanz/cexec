# cexec cluster configuration
# Copy this to cluster.env and fill in your values.
# cluster.env is gitignored — never commit passwords.

# ── Authentication ─────────────────────────────────────────────────────────────
# SSH + sudo password shared across all nodes.
CLUSTER_PASSWORD=yourpassword

# ── Inventory ──────────────────────────────────────────────────────────────────
# When CLUSTER_HOSTS_FILE is set, /etc/hosts is the primary IP source.
# cexec reads IPs from there, overlays group metadata from inventory.yaml,
# and automatically appends any new nodes (found in /etc/hosts but not in
# inventory.yaml) into inventory.yaml with default groups:
#   master → [control],  nodeN → [compute]
#
# To use inventory.yaml as the sole source instead (e.g. /etc/hosts is broken),
# comment out this line or pass --use-inventory on the CLI.
CLUSTER_HOSTS_FILE=/etc/hosts

# SSH user for all nodes (default: hpc)
CLUSTER_USER=hpc

# ── Playbook ───────────────────────────────────────────────────────────────────
# Default playbook to run (used when cexec is invoked with no --playbook flag)
CLUSTER_PLAYBOOK=hpc-setup.yaml

# ── Paths ──────────────────────────────────────────────────────────────────────
# Directory for JSON run logs (default: logs)
CLUSTER_LOG_DIR=logs

# Path to step-cache state file (default: .cexec_state.json)
# Delete this file to force a full re-run of all playbook steps.
CLUSTER_STATE_FILE=.cexec_state.json
